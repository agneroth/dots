# ============ Enconding/Crypto ============

sbuff () {
  read -s BUFF && echo "$BUFF" | sha512sum
  unset BUFF
}

b64 () {
  read -s BUFF && echo -n "$BUFF" | base64
  unset BUFF
}

b64d () {
  read -s BUFF && echo -n "$BUFF" | base64 -d
  unset BUFF
}

url () {
  read -s BUFF && cat <<EOF | python -
import urllib.parse as parse
print(parse.quote("$BUFF"))
EOF
}

urld () {
  read -s BUFF && cat <<EOF | python -
import urllib.parse as parse
print(parse.unquote("$BUFF"))
EOF
}

qr () {
  read -s BUFF && qrencode $BUFF -t ansiutf8
}

