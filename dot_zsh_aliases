# ============ bare worktrees ===========

gwit () {
  local repository_url=${1:?Please provide repository URL [1]}
  local target_dir=${2:?Please provite target URL [2]}

  if test -e "${target_dir}"; then
    echo "ERROR: ${target_dir} directory/file already exists" 2>&1
  fi

  mkdir "${target_dir}"
  git -C "${target_dir}" clone --bare "${repository_url}" ".bare"
  echo "gitdir: ./.bare" > "${target_dir}/.git"
  git -C "${target_dir}" config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"
}

gwtc () {
  local worktree=${1:?Please provide worktree/branch name [1]}
  local source_branch=${2:?Please provide source branch [2]}

  git worktree add ${worktree} ${source_branch} -b ${worktree}
}

wti () {
    cd "$(git worktree list | fzf | awk '{print $1}')"
}

# ============ Other ============

wgu () {
  TARGET_CONF=${1:-tardis.conf}
  sudo wg-quick up "$(goto -x vpn)/$TARGET_CONF"
}

wgf () {
  TARGET_CONF=${1:-tardis.conf}
  sudo wg-quick up "$(goto -x vpn)/$TARGET_CONF"
  OLD_PORT=0
  while true; do
    OUT_TPC=$(natpmpc -a 1 0 tcp 60 -g 10.2.0.1)
    OUT_UDP=$(natpmpc -a 1 0 udp 60 -g 10.2.0.1)
    UDP_PORT=$(echo "$OUT_UDP" | awk '/Mapped public port/ {print $4}')
    TCP_PORT=$(echo "$OUT_UDP" | awk '/Mapped public port/ {print $4}')
    
    if test $UDP_PORT != $TCP_PORT; then
        echo "Using UDP port $UDP_PORT over TCP port $TCP_PORT"
    fi
    PORT=$UDP_PORT

    if [ -z "$PORT" ]; then
        echo "Failed to obtain port, retrying in 30s..."
        sleep 30
        continue
    fi

    if test $PORT != $OLD_PORT; then
      curl --silent \
        --data "json={\"listen_port\":$PORT}" \
        "http://127.0.0.1:8080/api/v2/app/setPreferences"
      OLD_PORT=$PORT
      echo "Updated qBittorrent to listen on port $PORT"
    fi

    sleep 45
  done
}

wgd () {
  TARGET_CONF=${1:-tardis.conf}
  sudo wg-quick down "$(goto -x vpn)/$TARGET_CONF"
}

rgr () {
  # Inplace replacement using ripgrep and REGEX 
  # Requires scaping $1 and $2 special chars
  rg $1 --file-with-matches | xargs sed -i "s/$1/$2/g"
}

