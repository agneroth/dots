#!/bin/env zsh

# ============ Path config ============

# For enabling k8s krew 
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"

# Source go
export PATH="$HOME/go/bin:$PATH"
export GOPATH="$HOME/go"

# Source local binaries
export PATH="$HOME/.local/bin:$PATH"

# Nix
export PATH="$HOME/.nix-profile/bin:$PATH"

# ============ Editor config ============

{{- $hasNvim := lookPath "nvim" -}}
{{ if $hasNvim }}
alias v=nvim
alias vi=nvim
alias vim=nvim
{{ end }}

if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='vim'
else
  {{ if $hasNvim }}
  export EDITOR='nvim'
  {{ else }}
  export EDITOR='vim'
  {{ end }}
fi

# Change kubectl editor
export KUBE_EDITOR=$EDITOR

# Change systemd edit editor
# TODO: Need to change visudo also... (Defaults  env_keep += "SYSTEMD_EDITOR")
export SYSTEMD_EDITOR=$EDITOR

# Change default editor 
export VISUAL=$EDITOR

# Change git editor
export GIT_EDITOR=$EDITOR

# ============ Variables ============

export STARSHIP_CONFIG="${HOME}/.config/starship.toml"

# ============ Auxiliary Function ============

command_exists() {
  command -v "$@" >/dev/null 2>&1
}
{{- $hasOMZ := stat (printf "%s/.oh-my-zsh/oh-my-zsh.sh" .chezmoi.homeDir) -}}

{{- $hasDocker := lookPath "docker" -}}
{{- $hasDockerCompose := lookPath "docker-compose" -}}
{{- $hasHelm := lookPath "helm" -}}
{{- $hasGh := lookPath "gh" -}}
{{- $hasKubectl := lookPath "kubectl" -}}
{{- $hasStarship := lookPath "starship" -}}
{{- $hasFzf := lookPath "fzf" -}}
{{- $hasTerraform := lookPath "terraform" -}}
{{- $hasTldr := lookPath "tldr" -}}
{{- $hasPodman := lookPath "podman" -}}
{{- $hasZoxide := lookPath "zoxide" -}}
{{- $hasUv := lookPath "uv" -}}
{{- $hasFlux := lookPath "flux" -}}

{{- $hasZshAutosuggestions := stat (printf "%s/.oh-my-zsh/custom/plugins/zsh-autosuggestions" .chezmoi.homeDir) }}
{{- $hasZshSyntaxHighlighting := stat (printf "%s/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting" .chezmoi.homeDir) }}
{{- $hasGoto := stat (printf "%s/.local/share/goto/goto.sh" .chezmoi.homeDir) }}

{{ if $hasOMZ }}
# ============ ZSH Extensions (Oh My Zsh) ============

export ZSH="$HOME/.oh-my-zsh"
ZSH_CUSTOM="$HOME/.oh-my-zsh/custom"

ZSH_THEME="random"

plugins=(
    git
    ssh
    colorize
    alias-finder
    chezmoi
    {{ if $hasDocker -}} docker {{- end }}
    {{ if $hasDockerCompose -}} docker-compose {{- end }}
    {{ if $hasHelm -}} helm {{- end }}
    {{ if $hasGh -}} gh {{- end }}
    {{ if $hasKubectl -}} kubectl {{- end }}
    {{ if $hasStarship -}} starship {{- end }}
    {{ if $hasFzf -}} fzf {{- end }}
    {{ if $hasTerraform -}} terraform {{- end }}
    {{ if $hasTldr -}} tldr {{- end }}
    {{ if $hasPodman -}} podman {{- end }}
    {{ if not $hasZoxide -}} z {{- end }}
    {{ if $hasUv -}} uv {{- end }}
    {{ if $hasZshAutosuggestions -}} zsh-autosuggestions {{- end }}
    {{ if $hasZshSyntaxHighlighting -}} zsh-syntax-highlighting {{- end }}
    {{ if $hasFlux -}} fluxcd {{- end }}
)

zstyle ':omz:plugins:alias-finder' autoload yes
{{ if $hasDocker }}
zstyle ':completion:*:*:docker:*' option-stacking yes
zstyle ':completion:*:*:docker-*:*' option-stacking yes

{{ end -}}
{{ if $hasZshAutosuggestions }}
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=#999'

{{ end -}}
source "$ZSH/oh-my-zsh.sh"
{{ else }}
# ============ Fallback shell configuration ============

{{ if $hasKubectl -}} source <(kubectl completion zsh) {{- end }}
{{ if $hasHelm -}} source <(helm completion zsh) {{- end }}
{{ if $hasStarship -}} eval "$(starship init zsh)" {{- end }}
{{ if $hasFzf -}} source <(fzf --zsh) {{- end }}
{{ if $hasUv -}} source <(uv generate-shell-completion zsh) {{- end }}
{{ if $hasFlux -}} source <(flux completion bash) {{- end }}

{{ end -}}
{{ if $hasZoxide }}
# ============ Enable zoxide ============

eval "$(zoxide init zsh)"

{{- end }}
{{ if $hasGoto }}
# ============ enable goto =============
source ${HOME}/.local/share/goto/goto.sh

{{ end -}}
# ============ Fix keybindings ============

# Needs to run the following lines if the zkbd file does not exist
# autoload zkbd; zkbd

if test -f ~/.zkbd/$TERM-${${DISPLAY:t}:-$VENDOR-$OSTYPE}; then
    source ~/.zkbd/$TERM-${${DISPLAY:t}:-$VENDOR-$OSTYPE}
    
    [[ -n ${key[Backspace]} ]] && bindkey "${key[Backspace]}" backward-delete-char
    [[ -n ${key[Insert]} ]] && bindkey "${key[Insert]}" overwrite-mode
    [[ -n ${key[Home]} ]] && bindkey "${key[Home]}" beginning-of-line
    [[ -n ${key[PageUp]} ]] && bindkey "${key[PageUp]}" up-line-or-history
    [[ -n ${key[Delete]} ]] && bindkey "${key[Delete]}" delete-char
    [[ -n ${key[End]} ]] && bindkey "${key[End]}" end-of-line
    [[ -n ${key[PageDown]} ]] && bindkey "${key[PageDown]}" down-line-or-history
    [[ -n ${key[Up]} ]] && bindkey "${key[Up]}" up-line-or-search
    [[ -n ${key[Left]} ]] && bindkey "${key[Left]}" backward-char
    [[ -n ${key[Down]} ]] && bindkey "${key[Down]}" down-line-or-search
    [[ -n ${key[Right]} ]] && bindkey "${key[Right]}" forward-char
fi

