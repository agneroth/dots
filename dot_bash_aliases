# ============ Enconding/Crypto ============

sbuff () {
  read -s BUFF && echo "$BUFF" | sha512sum
  unset BUFF
}

b64 () {
  read -s BUFF && echo -n "$BUFF" | base64
  unset BUFF
}

b64d () {
  read -s BUFF && echo -n "$BUFF" | base64 -d
  unset BUFF
}

qr () {
  read -s BUFF && qrencode $BUFF -t ansiutf8
}

